<view class="nav-bar {{extClass}} {{fixed ? 'nav-bar--fixed' : ''}} {{transparent ? 'nav-bar--transparent' : ''}} {{blur ? 'nav-bar--blur' : ''}}" style="{{innerStyle}}">
  <view class="nav-bar__status-bar" style="height: {{statusBarHeight}}px;"></view>
  
  <view class="nav-bar__content" style="height: {{navBarHeight}}px;">
    <view class="nav-bar__left" style="width: {{menuButtonRight}}px;">
      <block wx:if="{{back}}">
        <view 
          class="nav-bar__btn nav-bar__btn--back" 
          bindtap="handleBack"
          hover-class="nav-bar__btn--active"
          hover-stay-time="100"
        >
          <text class="nav-bar__btn-icon">‹</text>
        </view>
      </block>
      <block wx:if="{{homeButton}}">
        <view 
          class="nav-bar__btn nav-bar__btn--home" 
          bindtap="handleHome"
          hover-class="nav-bar__btn--active"
          hover-stay-time="100"
        >
          <text class="nav-bar__btn-icon">🏠</text>
        </view>
      </block>
      <slot name="left"></slot>
    </view>

    <view class="nav-bar__center">
      <block wx:if="{{loading}}">
        <view class="nav-bar__loading">
          <view class="nav-bar__loading-icon"></view>
        </view>
      </block>
      <block wx:if="{{title}}">
        <text class="nav-bar__title">{{title}}</text>
      </block>
      <slot name="center"></slot>
    </view>

    <view class="nav-bar__right" style="width: {{menuButtonRight}}px;">
      <slot name="right"></slot>
    </view>
  </view>
</view>

<view wx:if="{{fixed && placeholder}}" class="nav-bar__placeholder" style="height: {{statusBarHeight + navBarHeight}}px;"></view>
