<view class="venues-container">
  <navigation-bar 
    title="附近的现场" 
    back="{{false}}"
    fixed="{{true}}"
    blur="{{true}}"
    bind:back="goBack"
  >
    <view slot="right" class="header-action" bindtap="openFilter">
      <text class="action-icon">⚙️</text>
    </view>
  </navigation-bar>
  
  <view class="search-bar">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索附近的现场" 
        value="{{searchText}}"
        bindinput="onSearchInput"
      />
    </view>
  </view>
  
  <scroll-view class="venues-content" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{!hasVenues}}" class="empty-state">
      <view class="empty-icon-wrapper">
        <text class="empty-icon">📍</text>
      </view>
      <view class="empty-title">附近暂无现场</view>
      <view class="empty-desc">你可以成为第一个开启这里的人</view>
      <button class="create-btn" bindtap="createVenue">
        <text class="create-icon">➕</text>
        去创建
      </button>
    </view>
    
    <block wx:else>
      <view class="section-title">热门现场</view>
      <view class="venues-list">
        <view 
          class="venue-item" 
          wx:for="{{venues}}" 
          wx:key="id"
          bindtap="goToVenueDetail"
          data-id="{{item.id}}"
        >
          <view class="venue-icon {{item.category}}">
            <text class="icon">{{item.icon}}</text>
          </view>
          <view class="venue-info">
            <view class="venue-name">{{item.name}}</view>
            <view class="venue-address">{{item.address}}</view>
            <view class="venue-meta">
              <text class="hot-icon" wx:if="{{item.isHot}}">🔥</text>
              <text class="meta-text {{item.isHot ? 'hot' : ''}}">{{item.postCount}}条实时说说</text>
            </view>
          </view>
          <view class="venue-arrow">
            <text class="arrow-icon">›</text>
          </view>
        </view>
      </view>
    </block>
  </scroll-view>
  
  <tab-bar activeTab="venues" />
</view>
